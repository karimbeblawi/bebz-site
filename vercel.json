{
  "rewrites": [
    { "source": "/arabic", "destination": "/arabic/index.html" },
    { "source": "/arabic/", "destination": "/arabic/index.html" }
  ],
  "headers": [
    {
      "source": "/demo/(.*)",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=31536000" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
